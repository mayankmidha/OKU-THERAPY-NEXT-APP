// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CLIENT)
  password      String?   // For credentials auth
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  clientProfile ClientProfile?
  therapistProfile TherapistProfile?
  clientBookings      Booking[] @relation("ClientBookings")
  therapistBookings      Booking[] @relation("TherapistBookings")
  assessments   Assessment[]
  moodEntries   MoodEntry[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClientProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  dateOfBirth DateTime?
  phone       String?
  address     String?
  emergencyContact String?
  medicalHistory String? @db.Text
  preferences Json?    // Store therapy preferences
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings    Booking[] @relation("ClientProfileBookings")
  assessments Assessment[] @relation("ClientAssessments")
  moodEntries MoodEntry[] @relation("ClientMoodEntries")
}

model TherapistProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  licenseNumber   String?
  specialization String[]
  experience      Int?     // years of experience
  bio             String?  @db.Text
  education       String?  @db.Text
  languages       String[]
  consultationFee Float?
  availability    Json?    // Store availability schedule
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[] @relation("TherapistProfileBookings")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  duration    Int      // minutes
  price       Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
}

model Booking {
  id            String       @id @default(cuid())
  clientId      String
  therapistId   String
  serviceId     String
  startTime     DateTime
  endTime       DateTime
  status        BookingStatus @default(SCHEDULED)
  notes         String?      @db.Text
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  client        User         @relation("ClientBookings", fields: [clientId], references: [id], map: "booking_client_id_fkey")
  therapist     User         @relation("TherapistBookings", fields: [therapistId], references: [id], map: "booking_therapist_id_fkey")
  service       Service      @relation(fields: [serviceId], references: [id])
  sessionNotes  SessionNote[]
  clientProfile ClientProfile? @relation("ClientProfileBookings", fields: [clientId], references: [userId])
  therapistProfile TherapistProfile? @relation("TherapistProfileBookings", fields: [therapistId], references: [userId])
}

model SessionNote {
  id        String   @id @default(cuid())
  bookingId String
  content   String   @db.Text
  isPrivate Boolean  @default(false) // visible to client or not
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Assessment {
  id          String           @id @default(cuid())
  clientId    String
  type        AssessmentType
  responses   Json             // Store assessment responses
  score       Float?
  result      String?          @db.Text
  interpretation String?       @db.Text
  completedAt DateTime         @default(now())
  createdAt   DateTime         @default(now())

  client      User             @relation(fields: [clientId], references: [id], map: "assessment_client_id_fkey")
  clientProfile ClientProfile? @relation("ClientAssessments", fields: [clientId], references: [userId], map: "assessment_client_profile_id_fkey")
}

model MoodEntry {
  id          String   @id @default(cuid())
  clientId    String
  mood        Int      // 1-10 scale
  notes       String?  @db.Text
  tags        String[]
  createdAt   DateTime @default(now())

  client      User     @relation(fields: [clientId], references: [id], map: "mood_entry_client_id_fkey")
  clientProfile ClientProfile? @relation("ClientMoodEntries", fields: [clientId], references: [userId], map: "mood_entry_client_profile_id_fkey")
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum AssessmentType {
  ADHD
  ANXIETY
  DEPRESSION
  BURNOUT
  TRAUMA
}
